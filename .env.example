# L2Earn env vars

# 1. WalletConnect project ID — required for the wallet modal to open.
#    Free, sign up at https://walletconnect.network
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# 2. Anthropic API key — used server-side to generate + grade quiz questions.
#    Optional: if unset, L2Earn falls back to a deterministic stub quiz.
#    Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# 3. Base Sepolia / EVM config for server-side reward transfers and NFT minting.
EVM_RPC_URL=https://sepolia.base.org
EVM_CHAIN_ID=84532

# 4. NFT milestone minting.
#    Set NFT_STANDARD=erc1155 for mint(address,uint256,uint256,bytes).
#    Set NFT_STANDARD=erc721 for mint(address,uint256) or safeMint(address,uint256).
NFT_CONTRACT_ADDRESS=
NFT_MINTER_PRIVATE_KEY=
NFT_STANDARD=erc1155
NFT_MINT_FUNCTION=mint
# Public deployed app URL used by ERC1155 metadata. Example: https://your-app.vercel.app
NFT_METADATA_BASE_URL=

# 5. Lumin eSign certificate config.
#    API docs: https://developers.luminpdf.com/api/lumin-api-reference/
#    Sandbox: https://api-sandbox.luminpdf.com/v1
#    Production: https://api.luminpdf.com/v1
LUMIN_API_BASE_URL=https://api-sandbox.luminpdf.com/v1
LUMIN_API_KEY=
# Optional. If empty, L2Earn generates a simple certificate PDF and sends it directly.
LUMIN_TEMPLATE_ID=
LUMIN_SIGNER_EMAIL=
LUMIN_SIGNER_NAME=L2Earn Issuer
# Optional if your Lumin template defines signer roles.
LUMIN_SIGNER_ROLE=
