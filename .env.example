# L2Earn env vars

# 1. WalletConnect project ID — required for the wallet modal to open.
#    Free, sign up at https://walletconnect.network
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# 2. Anthropic API key — used server-side to generate + grade quiz questions.
#    Optional: if unset, L2Earn falls back to a deterministic stub quiz.
#    Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# 3. Lumin eSign API — for digitally-signed learning certificates (Optional)
#    Get credentials at https://luminpdf.com
LUMIN_API_BASE_URL=https://api-sandbox.luminpdf.com/v1
LUMIN_API_KEY=
LUMIN_TEMPLATE_ID=
LUMIN_SIGNER_EMAIL=
LUMIN_SIGNER_NAME=L2Earn Issuer
LUMIN_SIGNER_ROLE=Educational Institution

# 4. NFT Contract & Minting Configuration (Optional)
#    To mint real NFTs, deploy an ERC721 or ERC1155 contract and set these
NFT_CONTRACT_ADDRESS=
NFT_MINTER_PRIVATE_KEY=
NFT_STANDARD=erc1155
NFT_MINT_FUNCTION=mint
